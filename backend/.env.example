APP_NAME=UMKMOrder
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost:8000

# Database Settings (Adjust DB_PASSWORD to match your local MySQL configuration)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=umkmorder
DB_USERNAME=root
DB_PASSWORD=

# Cache & Queue (Using 'database' instead of 'redis' simplifies native setup on Windows)
SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

# WhatsApp Configuration (Logged to storage/logs/laravel.log by default)
WHATSAPP_PROVIDER=fonnte
WHATSAPP_TOKEN=
WHATSAPP_GATEWAY_URL=
WHATSAPP_API_KEY=
