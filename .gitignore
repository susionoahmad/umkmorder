# Environment files
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example
frontend/.env
frontend/.env.*
!frontend/.env.example

# Dependencies
backend/vendor/
frontend/node_modules/

# Build output
frontend/dist/
frontend/.vite/

# Laravel generated files
backend/storage/*.key
backend/storage/app/*
backend/storage/framework/cache/*
backend/storage/framework/sessions/*
backend/storage/framework/testing/*
backend/storage/framework/views/*
backend/storage/logs/*
backend/bootstrap/cache/*.php
backend/public/uploads/

# Keep Laravel directories
!backend/storage/app/.gitignore
!backend/storage/framework/cache/.gitignore
!backend/storage/framework/sessions/.gitignore
!backend/storage/framework/testing/.gitignore
!backend/storage/framework/views/.gitignore
!backend/storage/logs/.gitignore

# Test and coverage output
coverage/
.phpunit.cache/
backend/.phpunit.cache/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS and editor files
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*.swo

# Local certificates and keys
*.pem
*.key
*.crt
# Vercel
.vercel
backend/.vercel
frontend/.vercel